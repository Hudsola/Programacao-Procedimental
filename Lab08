//EXERCICIO 2: NOME NUM MATRICULA CURSO
    struct cadastro{
        char nome[50];
        int num_matricula;
        char curso[50];
    };
    typedef struct cadastro cadastro;
int main(){
    cadastro c[4];
    int i, j;   // contadores
    for(i=0; i<5; i++){
    fflush(stdin);
    printf("\nNome: \n");
    gets(c[i].nome);
    printf("\nNumero de matricula: \n");
    scanf("%d",&c[i].num_matricula);
    printf("\nCurso: \n");
    fflush(stdin);
    gets(c[i].curso);
    }
    for (j=0; j<5; j++){
        printf("\n%s \n", c[j].nome);
        printf("\n%d \n", c[j].num_matricula);
        printf("\n%s \n", c[j].curso);
    }
    system("pause");

    return 0;
}
